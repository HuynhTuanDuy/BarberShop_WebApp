@page
@model BarberShop.Pages.Staff.IndexModel
@{
    ViewData["Title"] = "Staff Directory";
}

<style>
    .section-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 25px;
    }

    .section-title h2 {
        font-size: 24px;
        font-weight: 700;
        margin: 0;
        color: #e5e2e1;
        letter-spacing: 0.5px;
    }

    .section-title p {
        font-size: 13px;
        color: #8a8a8a;
        margin: 5px 0 0 0;
    }

    .btn-outline-custom {
        border: 1px solid #444;
        color: #e5e2e1;
        background: transparent;
        padding: 8px 16px;
        border-radius: 6px;
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 1px;
        display: inline-flex;
        align-items: center;
        gap: 5px;
        text-transform: uppercase;
        transition: all 0.2s;
        cursor: pointer;
        text-decoration: none;
    }

        .btn-outline-custom:hover {
            border-color: #f2ca50;
            color: #f2ca50;
            background: rgba(242, 202, 80, 0.05);
        }

    /* STAFF CARDS */
    .staff-card {
        background-color: #1a1a1a;
        border: 1px solid #333;
        border-radius: 8px;
        padding: 20px;
        display: flex;
        flex-direction: column;
        gap: 15px;
        height: 100%;
        transition: border-color 0.2s;
    }

        .staff-card:hover {
            border-color: #555;
        }

    .staff-info-row {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
    }

    .staff-profile {
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .staff-avatar {
        width: 64px;
        height: 64px;
        border-radius: 8px;
        object-fit: cover;
        border: 1px solid #333;
    }

    .staff-name {
        font-size: 18px;
        font-weight: 600;
        margin: 0;
        color: #e5e2e1;
    }

    .staff-role {
        font-size: 13px;
        color: #f2ca50;
        margin: 2px 0 6px 0;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .status-badge {
        padding: 5px 12px;
        border-radius: 20px;
        font-size: 11px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background-color: #222;
        border: 1px solid #333;
        color: #e5e2e1;
    }

    .status-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
    }

    .status-available .status-dot {
        background-color: #4caf50;
        box-shadow: 0 0 6px #4caf50;
    }

    .status-busy .status-dot {
        background-color: #8a8a8a;
        box-shadow: 0 0 6px #8a8a8a;
    }

    .staff-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-top: 1px solid #333;
        padding-top: 15px;
        margin-top: auto;
    }

    .tags {
        display: flex;
        gap: 8px;
    }

    .tag {
        font-size: 10px;
        font-weight: 700;
        color: #8a8a8a;
        background-color: #131313;
        padding: 4px 8px;
        border-radius: 4px;
        border: 1px solid #333;
        letter-spacing: 0.5px;
    }

    .more-options {
        color: #8a8a8a;
        cursor: pointer;
        transition: color 0.2s;
    }

        .more-options:hover {
            color: #fff;
        }

    /* Dropdown tùy chỉnh cho nền tối */
    .dropdown-menu-custom {
        background-color: #1e1e1e;
        border: 1px solid #444;
        box-shadow: 0 10px 30px rgba(0,0,0,0.5);
    }

    .dropdown-item-custom {
        color: #e5e2e1;
        font-size: 13px;
        font-weight: 500;
        padding: 8px 20px;
    }

        .dropdown-item-custom:hover {
            background-color: #333;
            color: #f2ca50;
        }
</style>

<div class="section-header">
    <div class="section-title">
        <h2>Danh sách Nhân viên</h2>
    </div>
    <a asp-page="./Create" class="btn-outline-custom">
        <span class="material-symbols-outlined" style="font-size: 16px;">add</span> Thêm NV
    </a>
</div>

<div class="row">
    @foreach (var item in Model.Users)
    {
        <div class="col-xl-6 col-lg-6 mb-4">
            <div class="staff-card">
                <div class="staff-info-row">
                    <div class="staff-profile">
                        <img src="@(string.IsNullOrEmpty(item.Avatar) ? $"https://ui-avatars.com/api/?name={Uri.EscapeDataString(item.FullName)}&background=222&color=f2ca50&size=128" : item.Avatar)" class="staff-avatar" alt="Avatar" />
                        <div>
                            <h3 class="staff-name">@item.FullName</h3>
                            <p class="staff-role">@item.Role</p>
                            <div class="mt-1" style="font-size: 12px; color: #8a8a8a;">
                                User: @item.UserName
                            </div>
                        </div>
                    </div>

                    @if (item.IsActive == 1)
                    {
                        <div class="status-badge status-available">
                            <span class="status-dot"></span> Available
                        </div>
                    }
                    else
                    {
                        <div class="status-badge status-busy">
                            <span class="status-dot"></span> Inactive
                        </div>
                    }
                </div>
                <div class="staff-footer">
                    <div class="tags">
                        <span class="tag">ID: #@item.UserID.ToString("D3")</span>
                    </div>

                    <div class="dropdown">
                        <span class="material-symbols-outlined more-options" data-bs-toggle="dropdown" aria-expanded="false">
                            more_vert
                        </span>
                        <ul class="dropdown-menu dropdown-menu-custom dropdown-menu-end">
                            <li>
                                <a class="dropdown-item dropdown-item-custom d-flex align-items-center gap-2" asp-page="./Edit" asp-route-id="@item.UserID">
                                    <span class="material-symbols-outlined" style="font-size: 16px;">edit</span> Chỉnh sửa
                                </a>
                            </li>
                            <li><hr class="dropdown-divider" style="border-color: #333;"></li>
                            <li>
                                <a class="dropdown-item dropdown-item-custom text-danger d-flex align-items-center gap-2" asp-page="./Delete" asp-route-id="@item.UserID">
                                    <span class="material-symbols-outlined" style="font-size: 16px;">delete</span> Xóa hồ sơ
                                </a>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    }
</div>