@page
@model BarberShop.Pages.Services.CreateModel

@{
    ViewData["Title"] = "Thêm dịch vụ mới";
    Layout = null;
}

<style>
    /* Sử dụng chung style với Edit ở trên */
    body {
        background-color: #131313;
        color: #e5e2e1;
        font-family: 'Inter', sans-serif;
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 100vh;
        margin: 0;
    }

    .card-box {
        background-color: #1e1e1e;
        border: 1px solid #333;
        border-radius: 8px;
        width: 450px;
        padding: 30px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.5);
    }

    .label-custom {
        font-size: 11px;
        font-weight: 700;
        color: #8a8a8a;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        margin-bottom: 8px;
        display: block;
    }

    .input-custom {
        width: 100%;
        background: #2a2a2a;
        border: 1px solid #444;
        border-radius: 4px;
        padding: 12px;
        color: #fff;
        margin-bottom: 20px;
        box-sizing: border-box;
    }

        .input-custom:focus {
            border-color: #f2ca50;
            outline: none;
        }

    .btn-group {
        display: flex;
        gap: 10px;
        margin-top: 10px;
    }

    .btn {
        flex: 1;
        padding: 12px;
        border: none;
        border-radius: 4px;
        font-weight: 700;
        cursor: pointer;
        text-transform: uppercase;
        font-size: 12px;
        letter-spacing: 1px;
    }

    .btn-cancel {
        background: #333;
        color: #fff;
        text-align: center;
        text-decoration: none;
        padding-top: 14px;
    }

    .btn-save {
        background: #f2ca50;
        color: #131313;
    }
</style>

<div class="card-box">
    <h2 style="font-size: 20px; margin-bottom: 25px; color: #f2ca50;">THÊM DỊCH VỤ MỚI</h2>
    <form method="post">
        <label class="label-custom">TÊN DỊCH VỤ</label>
        <input asp-for="Service.ServiceName" class="input-custom" placeholder="Ví dụ: Cắt tóc nam..." />

        <label class="label-custom">MỨC GIÁ (VNĐ)</label>
        <input asp-for="Service.Price" type="number" class="input-custom" placeholder="Ví dụ: 100000" />

        <div class="btn-group">
            <a asp-page="./Index" class="btn btn-cancel">QUAY LẠI</a>
            <button type="submit" class="btn btn-save">HOÀN THÀNH </button>
        </div>
    </form>
</div>