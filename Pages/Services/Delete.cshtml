@page "{id:int}"
@model BarberShop.Pages.Services.DeleteModel

@{
    ViewData["Title"] = "Xác Nhận Xóa";
    Layout = null;
}

<style>
    body {
        background-color: #131313;
        color: #e5e2e1;
        font-family: 'Inter', sans-serif;
        display: flex;
        justify-content: center;
        align-items: center;
        height: 100vh;
        margin: 0;
    }

    .modal-box {
        background-color: #1e1e1e;
        border: 1px solid #333;
        border-radius: 8px;
        width: 400px;
        padding: 24px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.6);
    }

    .modal-header {
        display: flex;
        align-items: flex-start;
        gap: 15px;
        margin-bottom: 20px;
    }

    .icon-alert {
        color: #ff4d4d;
        font-size: 48px; 
        margin-right: 10px;
    }

    h2 {
        font-size: 18px;
        margin: 0;
        color: #e5e2e1;
    }

    p {
        font-size: 14px;
        color: #a3a3a3;
        margin-top: 5px;
        line-height: 1.5;
    }

    .service-name {
        color: #f2ca50;
        font-weight: bold;
    }

    .btn-group {
        display: flex;
        justify-content: flex-end;
        gap: 10px;
        margin-top: 25px;
    }

    .btn {
        padding: 8px 20px;
        border-radius: 4px;
        font-size: 14px;
        cursor: pointer;
        border: none;
        font-weight: 600;
    }

    .btn-cancel {
        background: #2a2a2a;
        color: #e5e2e1;
    }

        .btn-cancel:hover {
            background: #333;
        }

    .btn-delete {
        background: #e28787;
        color: #131313;
    }

        .btn-delete:hover {
            background: #d96e6e;
        }
</style>

<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet" />

<div class="modal-box">
    <div class="modal-header">
        <span class="material-symbols-outlined icon-alert">error</span>
        <div>
            <h2>Xóa Dịch vụ?</h2>
            <p>Bạn có chắc chắn muốn xóa dịch vụ <span class="service-name">@Model.Service.ServiceName</span>? Thao tác này không thể hoàn tác.</p>
        </div>
    </div>

    <form method="post">
        <input type="hidden" asp-for="Service.ServiceID" />
        <div class="btn-group">
            <a asp-page="./Index" class="btn btn-cancel">HỦY</a>
            <button type="submit" class="btn btn-delete">XÓA</button>
        </div>
    </form>
</div>